{
  "name": "aoe4-game-analyzer-web",
  "version": "0.1.0",
  "private": true,
  "description": "Web app for AoE4 post-match analysis",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "check:no-root-imports": "node scripts/check-no-root-imports.mjs",
    "test": "jest --runInBand",
    "test:unit": "jest --runInBand __tests__/unit",
    "test:integration": "jest --runInBand __tests__/integration",
    "test:e2e": "jest --runInBand __tests__/e2e",
    "verify": "npm run check:no-root-imports && npm run typecheck && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.0",
    "axios": "^1.6.8",
    "next": "^16.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.3.6"
  },
  "overrides": {
    "postcss": "^8.5.13"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.1.0",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "nock": "^13.4.0",
    "ts-jest": "^29.2.3",
    "typescript": "^5.5.4"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "json"
    ],
    "testMatch": [
      "**/__tests__/**/*.(test|spec).ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/.next/"
    ]
  }
}
