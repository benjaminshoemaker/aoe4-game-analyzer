{
  "name": "aoe4-game-analyzer",
  "version": "0.1.0",
  "private": true,
  "description": "CLI tool for fetching and inspecting static Age of Empires IV data",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "bin": {
    "aoe4-analyze": "dist/index.js"
  },
  "scripts": {
    "cli": "ts-node src/index.ts",
    "check:core-boundary": "node scripts/check-aoe4-core-boundary.mjs",
    "prebuild": "npm --workspace @aoe4/analyzer-core run build",
    "build": "tsc -p tsconfig.json",
    "pretest": "npm --workspace @aoe4/analyzer-core run build",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "verify": "npm run check:core-boundary && npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.0",
    "axios": "^1.6.8",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^17.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.1.0",
    "jest": "^29.7.0",
    "jsdom": "^22.1.0",
    "nock": "^13.4.0",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": "20.x"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "testMatch": [
      "**/__tests__/**/*.(test|spec).ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/dist/"
    ]
  }
}
