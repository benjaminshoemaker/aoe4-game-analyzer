{
  "name": "@aoe4/analyzer-core",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test:unit": "jest --config ../../package.json --runInBand __tests__/unit",
    "test:integration": "jest --config ../../package.json --runInBand __tests__/integration",
    "test:e2e": "jest --config ../../package.json --runInBand __tests__/e2e",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "verify": "npm run build && npm run test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.72.0",
    "axios": "^1.6.8"
  },
  "devDependencies": {
    "@types/node": "^22.1.0",
    "typescript": "^5.5.4"
  }
}
